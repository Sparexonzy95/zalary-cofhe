{
  "name": "zalary-cofhe",
  "version": "1.0.0",
  "description": "Zalary confidential payroll — ported from Inco/TEE to CoFHE (Fhenix)",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "test:local": "COFHE_SKIP_MOCKS_DEPLOY=0 npx hardhat test --network hardhat",
    "deploy:sepolia": "npx hardhat ignition deploy ignition/modules/ZalaryDeploy.ts --network eth-sepolia",
    "deploy:arb": "npx hardhat ignition deploy ignition/modules/ZalaryDeploy.ts --network arb-sepolia",
    "node": "npx hardhat node"
  },
  "devDependencies": {
    "@cofhe/hardhat-plugin": "^0.4.0",
    "@cofhe/mock-contracts": "^0.4.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "chai": "^4.3.10",
    "hardhat": "^2.28.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@cofhe/sdk": "^0.4.0",
    "@fhenixprotocol/cofhe-contracts": "^0.1.3",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^17.3.1"
  }
}
